            "body": {
              "mode": "raw",
              "raw": "{\n  \"typeId\": \"0\",\n  \"title\": { \"en\": \"New Property\", \"de\": \"Neue Immobilie\" },\n  \"slug\": { \"en\": \"new-property\", \"de\": \"neue-immobilie\" },\n  \"price\": 400000,\n  \"livingArea\": 90,\n  \"statusId\": 177,\n  \"regionId\": 149,\n  \"totalRooms\": 3,\n  \"roomCountSearch\": 2,\n  \"yearBuilt\": 2022,\n  \"featured\": false,\n  \"address\": { \"en\": \"Sample Street 1, Berlin\", \"de\": \"Musterstraße 1, Berlin\" },\n  \"description\": { \"en\": \"A great property.\", \"de\": \"Eine tolle Immobilie.\" },\n  \"overview\": { \"area\": 90, \"bedrooms\": 2, \"bathrooms\": 1 },\n  \"agent\": { \"name\": \"Test Agent\", \"image\": \"/images/user.png\", \"logo\": \"/images/logo-dark.png\" }\n}"
