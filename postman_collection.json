        },
        {
          "name": "GET All Properties (Filtered)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/properties?typeId=0&statusId=177&minPrice=300000&maxPrice=500000&rooms=2",
              "host": ["{{base_url}}"],
              "path": ["properties"],
              "query": [
                { "key": "typeId", "value": "0" },
                { "key": "statusId", "value": "177" },
                { "key": "minPrice", "value": "300000" },
                { "key": "maxPrice", "value": "500000" },
                { "key": "rooms", "value": "2" },
                { "key": "regionId", "value": "", "disabled": true },
                { "key": "minArea", "value": "", "disabled": true },
                { "key": "featured", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "GET Property by ID",
